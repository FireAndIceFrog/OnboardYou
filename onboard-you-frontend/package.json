{
  "name": "onboard-you-frontend",
  "private": true,
  "scripts": {
    "dev:platform": "pnpm --filter @onboard-you/platform dev",
    "dev:config": "pnpm --filter @onboard-you/config dev",
    "dev:mock": "pnpm --filter @onboard-you/config run dev:mock:build && pnpm -r --parallel dev:mock",
    "build:platform": "pnpm --filter @onboard-you/platform build",
    "build:config": "pnpm --filter @onboard-you/config build",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}
