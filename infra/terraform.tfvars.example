# Copy to terraform.tfvars and customise
aws_region         = "ap-southeast-2"
environment        = "staging"
env_postfix        = "a1b2"
log_retention_days = 14

tags = {
  Project   = "OnboardYou"
  ManagedBy = "OpenTofu"
}

demo_users = [
  { email = "demo@onboardyou.com", organization_id = "qa-org" },
  # { email = "qa@onboardyou.com", organization_id = "qa-org" },
]

# Environment: "local" (CORS=*), "staging" (GitHub Pages), "prod" (S3+CloudFront)
# environment = "prod"

# Supabase provisioning ----------------------------------------------------
# You need an access token with project creation rights. Obtain from
# https://app.supabase.com/account/tokens
# supabase_access_token = "sbp_xxx"

# Organization slug appearing in dashboard URL, e.g. continued-brown-smelt
# supabase_organization_id = "your-org-slug"
