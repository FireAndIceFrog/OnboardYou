# Copy to terraform.tfvars and customise
aws_region         = "ap-southeast-2"
environment        = "dev"
env_postfix        = "a1b2"
log_retention_days = 14

tags = {
  Project   = "OnboardYou"
  ManagedBy = "OpenTofu"
}

demo_users = [
  { email = "demo@onboardyou.com", organization_id = "qa-org" },
